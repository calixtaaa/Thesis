# Copy to your environment (systemd, shell profile, or export before running main.py).
# Use the service_role key from Supabase Dashboard → Settings → API (server-side only).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Website reads `live_feed` with the logged-in user's JWT (role `authenticated`), not service_role.
# If the dashboard shows ₱0.00 but the machine can INSERT, add a SELECT policy in Supabase SQL, e.g.:
#   create policy "authenticated read live_feed"
#     on public.live_feed for select to authenticated using (true);

# Optional Pi heartbeat for dashboard (Prediction tab): table public.machine_telemetry with columns
# like cpu_temp_c (numeric), ram_pct (numeric), online (boolean), created_at (timestamptz default now()).
# Enable Realtime if you want live updates without polling.
